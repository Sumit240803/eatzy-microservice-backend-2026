            { "listen": "test", "script": { "type": "text/javascript", "exec": ["const j = pm.response.json();", "if (j && j.data) {", "  pm.collectionVariables.set('ownerToken', j.data.token);", "  pm.collectionVariables.set('ownerId', j.data.user.id);", "  pm.collectionVariables.set('token', j.data.token);", "}", "pm.test('201 created', () => pm.response.to.have.status(201));"] } }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Restaurant Owner\",\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"secret123\",\n  \"role\": \"OWNER\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
