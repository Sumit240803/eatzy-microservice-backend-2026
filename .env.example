# Optional overrides for `docker compose up`. Copy to `.env` (same directory as
# docker-compose.yml) and edit. Every value has a working default, so the stack
# runs with no .env at all.

# Shared Postgres password (used in every service's DATABASE_URL).
POSTGRES_PASSWORD=1234

# Must be identical for gateway + auth, or token verification fails.
JWT_SECRET=dev-secret-change-me

# Payments. Leave STRIPE_SECRET_KEY empty to run the payment provider in mock
# mode. Set a Stripe test key (sk_test_...) to use real Stripe.
PAYMENT_CURRENCY=inr
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Notifications email. Leave SMTP_HOST empty to use an Ethereal test account.
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASS=<api-key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Eatzy <no-reply@eatzy.local>
